# ─────────────────────────────────────────────
#  MARKET MAKER — environment variables
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Primary exchange (where orders are placed) ──
PRIMARY_EXCHANGE=binance
PRIMARY_API_KEY=YOUR_API_KEY
PRIMARY_API_SECRET=YOUR_API_SECRET
# Optional passphrase (Coinbase Advanced, OKX, etc.)
PRIMARY_PASSPHRASE=

# ── Reference exchange (price source / correlation) ──
REFERENCE_EXCHANGE=kraken
REFERENCE_API_KEY=
REFERENCE_API_SECRET=

# ── Trading pair ──
SYMBOL=BTC/USDT

# ── Strategy parameters ──
# Spread around mid-price (e.g. 0.002 = 0.2%)
SPREAD=0.002

# Order size in base currency (e.g. 0.001 BTC per side)
ORDER_SIZE=0.001

# Number of ladder levels on each side
LEVELS=3

# Size multiplier per level (e.g. 1.5 = each deeper level is 1.5x bigger)
LEVEL_SIZE_MULTIPLIER=1.5

# Spacing multiplier per level (extra spread per level, e.g. 0.001 = +0.1%)
LEVEL_SPACING=0.001

# How often the bot refreshes orders (seconds)
REFRESH_INTERVAL=10

# ── Price target (leave blank to use reference exchange mid) ──
# Set a fixed price the bot targets, e.g. 42000.00
TARGET_PRICE=

# ── Volume generation ──
# Enable self-trade volume generation (use with caution, check exchange ToS)
VOLUME_GENERATION=false
VOLUME_INTERVAL=30
VOLUME_MIN_SIZE=0.0001
VOLUME_MAX_SIZE=0.0005

# ── Price correlation ──
# Weight of reference exchange price vs target price (0.0–1.0)
# 1.0 = fully follow reference exchange, 0.0 = use TARGET_PRICE only
CORRELATION_WEIGHT=0.7

# Max allowed deviation from reference price before pausing (e.g. 0.05 = 5%)
MAX_PRICE_DEVIATION=0.05

# ── Risk controls ──
MAX_POSITION_BASE=0.1
MAX_POSITION_QUOTE=5000
INVENTORY_SKEW=true
DRY_RUN=true
